<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
</head>
<body>
    <h3>Edit Your Listing</h3>
    <form method="POST" action="/listing/<%= Listing._id %>?_method=PUT">
        <fieldset>
            <legend>Edit Listing Details</legend>
            <label for="title">Title:</label>
            <input type="text" id="title" name="Listing[title]" value="<%= Listing.title %>" required>
            <br><br>

            <label for="description">Description:</label>
            <input type="text" id="description" name="Listing[description]" value="<%= Listing.description %>" required>
            <br><br>

            <label for="image">Image URL:</label>
            <input type="text" id="image" name="Listing[image]" value="<%= Listing.image.url %>" required>
            <br><br>

            <label for="price">Price:</label>
            <input type="number" id="price" name="Listing[price]" value="<%= Listing.price %>" required>
            <br><br>

            <label for="country">Country:</label>
            <input type="text" id="country" name="Listing[country]" value="<%= Listing.country %>" required>
            <br><br>

            <label for="location">Location:</label>
            <input type="text" id="location" name="Listing[location]" value="<%= Listing.location %>" required>
            <br><br>
            
            <button type="submit">Edit</button>
        </fieldset>
    </form>
</body>
</html>
