<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust

    </title>
</head>
<body>
    <h3>All Listings</h3>
    <form method="GET" action="/listing/new">
        <button>Add new Listing</button>
    </form>
   
    <ul>
    <% for(let listing of allListing){ %>
         <h5><a href="/listing/<%=listing._id%>"><li><%= listing.title%></li></a></h5>
   <% }%>
</ul>
</body>
</html>
