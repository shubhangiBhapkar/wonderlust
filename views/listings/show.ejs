<% layout('/layouts/boilerplate')%>

    <body>
        <div class="row">
            <div class="col-8 offset-2">
                <h3>Listing Details</h3>
            </div>

            <div class="card col-6 offset-2 show-img">
                <img src="<%= Listing.image %>" class="card-img-top" alt="listing-image">

                <div class="card-body">
                    <p class="card-text mt-3">
                        <b>
                            <%= Listing.title %>
                        </b><br>
                        <%= Listing.description %><br>
                            &#8377;<%= Listing.price.toLocaleString("en-IN")%><br>
                                <%= Listing.location %><br>
                                    <%= Listing.country %><br>
                    </p>
                </div>
            </div>
        </div>

        <div class="btns">
            <a href="/listing/<%=Listing._id%>/edit" class="btn col-1 offset-2">Edit</a>
            <form method="POST" action="/listing/<%= Listing._id %> ">
                <button class="btn col-1 offset-2">Delete</button>
            </form>
        </div>
        </div>
    </body>